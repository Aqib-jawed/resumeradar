# ── DATABASE (Supabase) ─────────────────────────────────────
# Get from: Supabase → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ── NEXTAUTH ────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-generated-secret-here"

# ── GOOGLE OAUTH ────────────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── GROQ API ────────────────────────────────────────────────
# Get from: console.groq.com → API Keys (free tier available)
GROQ_API_KEY=""

# ── SUPABASE STORAGE ─────────────────────────────────────────
# Get from: Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ── REDIS (Upstash) — optional, for job queue ───────────────
# Get from: upstash.com → Create Database → REST URL
REDIS_URL=""